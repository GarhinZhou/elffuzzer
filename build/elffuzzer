#!/bin/bash

DEFAULT_PREFIX="/lib/x86_64-linux-gnu"
BLUE="\033[0;34m"
RED="\033[0;31m"
NC="\033[0m"

ELFADDR="$1"

if [ -z "$ELFADDR" ]; then
    echo -e "${RED}ERROR${NC} : Must attach elfpath."
    echo -e "${BLUE}Usage${NC} : $0 <ELFpath>"
    exit 1
fi
if [ ! -f "$ELFADDR" ]; then
    echo -e "${RED}ERROR${NC} : '$ELFADDR' is not a file!"
    exit 1
fi

echo "elf_addr : $ELFADDR"

TIME=$(date "+%F_%T")
mkdir /output/$TIME/

afl-fuzz -Q -i /input -o /output/$TIME/ $ELFADDR -f